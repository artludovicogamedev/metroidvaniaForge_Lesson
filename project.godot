; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="New Game Project"
run/main_scene="uid://bi3krjsipmw2b"
config/features=PackedStringArray("4.5", "Mobile")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://b8wr0hwoqop4v"

[autoload]

SceneManager="*res://global/scene_manager/scene_manager.tscn"
SaveManager="*res://global/save_manager.gd"
Messages="*res://global/messages.gd"
PlayerHud="*res://UI/PlayerHUD/PlayerHUD.tscn"
Audio="*res://global/Audio/Audio.tscn"
Visualfx="*res://global/VisualFX/visualfx.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/mode=2
window/size/window_width_override=1440
window/size/window_height_override=810
window/stretch/mode="canvas_items"

[file_customization]

folder_colors={
"res://player/": "blue",
"res://script_templates/": "teal",
"res://script_templates/DecisionEngine/": "red",
"res://script_templates/EnemyState/": "red"
}

[global_group]

Player=""

[gui]

theme/custom_font="uid://b6k1twkuv26kx"

